APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/jobscouter
DATABASE_URL_DOCKER=postgresql+psycopg://postgres:postgres@db:5432/jobscouter
LOG_LEVEL=INFO
REQUEST_TIMEOUT=20
REMOTEOK_API_URL=https://remoteok.com/api
REMOTAR_BASE_URL=https://remotar.com.br
REMOTAR_API_URL=https://api.remotar.com.br
USER_AGENT=jobscouter-ingestion-bot/0.1
GEMINI_API_KEY=aaaaaaaaaaaaaaaaaaaaa
GEMINI_MODEL=gemini-1.5-flash-latest
GEMINI_RETRY_DELAY_SECONDS=1.5
POSTGRES_DB=jobscouter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Frontend (Next.js) - atras do NGINX
NEXT_PUBLIC_API_BASE_PATH=/api/v1
